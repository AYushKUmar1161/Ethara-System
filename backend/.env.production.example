# ============================================================
# Ethara Backend — Production Environment Variables Template
# ============================================================
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the actual .env file to version control.

# --- Application ---
ENVIRONMENT=production
PORT=8000

# --- Database (PostgreSQL) ---
# Example for Neon.tech: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/ethara?ssl=require
# Example for Supabase:  postgresql+asyncpg://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/ethara

# --- Redis ---
# Example for Upstash: rediss://default:TOKEN@HOST:PORT
# Example for Redis Cloud: redis://default:pass@redis-host:port
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# --- JWT Security ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY_64_CHARS_MINIMUM
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated list of allowed frontend origins) ---
# Add your Vercel URL and any custom domain
BACKEND_CORS_ORIGINS=https://ethara.vercel.app,https://your-custom-domain.com

# --- AI / LLM Keys (Optional) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
